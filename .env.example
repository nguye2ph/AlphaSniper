# ============================================
# AlphaSniper — Environment Variables
# Copy to .env and fill in values
# ============================================

# --- API Keys (required) ---
# Get free key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here
# Get free key at https://www.marketaux.com/register
MARKETAUX_API_KEY=your_marketaux_api_key_here
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# --- Finnhub Watchlist ---
FINNHUB_SYMBOLS=["AAPL","TSLA","MSFT","NVDA","AMD"]

# --- PostgreSQL ---
POSTGRES_USER=alpha
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=alpha_sniper

# --- MongoDB ---
MONGO_URI=mongodb://mongo:27017
MONGO_DB=alpha_sniper

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- API Domain (Traefik SSL) ---
# Subdomain pointing to your VPS IP, or just use IP:8200 without Traefik
API_DOMAIN=api.yourdomain.com
ACME_EMAIL=your@email.com

# --- Frontend URL (Vercel, for CORS) ---
FRONTEND_URL=https://your-app.vercel.app

# --- Market Cap Filter ---
# Skip articles > this value (USD). Only applies to new sources (TickerTick, Discord)
MARKET_CAP_LIMIT=100000000

# --- Discord NuntioBot Scraping ---
# User token from throwaway Discord account (NOT bot token)
DISCORD_TOKEN=
# Comma-separated channel IDs to monitor
DISCORD_CHANNEL_IDS=
# Bot username to match (default: NuntioBot)
NUNTIO_BOT_NAME=NuntioBot

# --- Discord Webhook (Outbound Alerts) ---
DISCORD_WEBHOOK_URL=                    # https://discord.com/api/webhooks/xxx/yyy (empty = disabled)
DISCORD_SENTIMENT_THRESHOLD=0.5         # Alert when |sentiment| > this value

# --- SEC EDGAR ---
SEC_EDGAR_USER_AGENT=AlphaSniper/1.0 (your@email.com)

# --- App Settings ---
APP_ENV=production
LOG_LEVEL=INFO
API_PORT=8200
