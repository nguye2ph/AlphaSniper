# AlphaSniper Environment Variables

# MongoDB (raw zone)
MONGO_URI=mongodb://localhost:27017
MONGO_DB=alpha_sniper

# PostgreSQL (clean zone)
POSTGRES_URL=postgresql+asyncpg://alpha:alpha_dev_only@localhost:5432/alpha_sniper
POSTGRES_USER=alpha
POSTGRES_PASSWORD=alpha_dev_only
POSTGRES_DB=alpha_sniper

# Redis (queue + cache + dedup)
REDIS_URL=redis://localhost:6379/0

# Finnhub (primary data source)
# Get free key at https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key_here

# MarketAux (secondary data source)
# Get free key at https://www.marketaux.com/register
MARKETAUX_API_KEY=your_marketaux_api_key_here

# Google Gemini (AI parser - Phase 7)
# Get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# SEC EDGAR (no key needed, but requires contact email)
SEC_EDGAR_USER_AGENT=AlphaSniper/1.0 (your_email@example.com)

# Application
APP_ENV=development
LOG_LEVEL=INFO
API_PORT=8200
